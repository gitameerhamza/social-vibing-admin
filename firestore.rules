rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if user ID matches
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user is community moderator
    function isCommunityModerator(communityId) {
      let community = get(/databases/$(database)/documents/communities/$(communityId));
      return isSignedIn() && 
             (community.data.creatorId == request.auth.uid || 
              request.auth.uid in community.data.moderators);
    }
    
    // Helper function to check if user is verified (17+)
    function isVerified() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerified == true;
    }
    
    // ========== MARKETPLACE COLLECTIONS ==========
    
    // Products - anyone can read, special write rules
    match /products/{productId} {
      allow read: if true;
      allow create: if request.resource.data.isOfficial == true && 
                      request.resource.data.creatorId == 'official';
      allow create: if isSignedIn() && 
                      request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isSignedIn() && 
                               resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['stats']);
      // Allow admins to mark products as deleted
      allow update: if isAdmin() && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['isDeleted', 'deletedAt', 'deletedBy']);
      // Allow admins to delete products
      allow delete: if isAdmin();
    }
    
    // Users collection - allow wallet and ownedProducts updates for purchases
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);

      // Full update for own doc
      allow update: if isOwner(userId);
      
      // Admin can update verification status and moderation fields
      allow update: if isAdmin() && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isVerified', 'verificationStatus', 'verifiedAt', 'verifiedBy', 
                    'isBanned', 'banType', 'banReason', 'bannedAt', 'banExpiresAt', 'bannedBy',
                    'unbannedAt', 'unbannedBy', 'warnings', 'lastWarning', 'lastWarningDate',
                    'warnedAt', 'warnedBy', 'revokedAt', 'revokedBy',
                    'warningsCount', 'isSuspended', 'suspendedReason', 'suspendedAt', 'suspendedBy',
                    'accountStatus']);

      // Only followers/following counters
      allow update: if isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followersCount', 'followingCount']);

      // Only wallet-related fields: wallet, coins, diamonds, ownedProducts
      allow update: if isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['wallet', 'coins', 'diamonds', 'ownedProducts']);

      // Allow any authenticated user to update reporting stats
      allow update: if isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reportsReceived', 'lastReportedAt']);
      
      // User's hidden posts (Web App)
      match /hidden/{postId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      // User's saved posts (Web App)
      match /saved/{postId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      // User's bookmarks (Web App)
      match /bookmarks/{postId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
    
    // Libraries - users can read and write their own
    match /libraries/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow write: if isSignedIn() && isOwner(userId);
    }
    
    // Orders - buyers can read their orders, Cloud Functions create
    match /orders/{orderId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    
    // Wallets - users can read their own, Cloud Functions manage
    match /wallets/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow write: if false;
    }
    
    // Transactions - users can read their own
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    
    // Daily Rewards - users can only access their own
    match /dailyRewards/{rewardId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    // Ad Rewards - users can only access their own
    match /adRewards/{rewardId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    // Withdrawals - users can only access their own
    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // Reviews - anyone can read, authenticated users can create their own
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ========== END MARKETPLACE COLLECTIONS ==========
    
    // Audio calls collection
    match /audio_calls/{communityId}/rooms/{roomId} {
      allow create: if isSignedIn() &&
                      request.resource.data.createdBy == request.auth.uid;
      allow read: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
      
      match /chat/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }
    
    // Voice/Video Calls
    match /calls/{callId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                      request.resource.data.callerId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
      
      match /chat/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }
    
    // Communities collection
    match /communities/{communityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Allow creator/moderators to update community
      allow update: if isSignedIn() && isCommunityModerator(communityId);
      // Allow anyone to update member-related fields
      allow update: if isSignedIn() && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['members', 'memberCount']);
      // Allow admins to disable communities
      allow update: if isAdmin() && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['isDisabled', 'disabledAt', 'disabledBy', 'disabledReason']);
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      
      match /posts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && 
                        (resource.data.authorId == request.auth.uid || 
                         isCommunityModerator(communityId));
        // Allow admins to delete posts
        allow delete: if isAdmin();
        // Allow post author or community moderators to delete
        allow delete: if isSignedIn() && 
                        (resource.data.authorId == request.auth.uid || 
                         isCommunityModerator(communityId));
        
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
          // Allow admins to delete comments
          allow delete: if isAdmin();
          allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
        }
      }
      
      match /blogs/{blogId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        // Allow admins to delete blogs
        allow delete: if isAdmin();
        allow delete: if isSignedIn() && 
                        (resource.data.authorId == request.auth.uid || 
                         get(/databases/$(database)/documents/communities/$(communityId)).data.uid == request.auth.uid);
        
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
          // Allow admins to delete comments
          allow delete: if isAdmin();
          allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
        }
      }
      
      match /drafts/{draftId} {
        allow read: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
      
      match /groups/{groupId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
        
        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn();
          allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
        }
        
        match /members/{memberId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn();
          allow delete: if isSignedIn() && memberId == request.auth.uid;
        }
      }
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }
    
    // Community chats
    match /community_chats/{communityId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }
    
    // Community members
    match /communities_members/{membershipId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Helper function to check conversation participant
    function isConversationParticipant(conversationId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }
    
    // Helper function to check conversation admin
    function isConversationAdmin(conversationId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.admins;
    }
    
    // Private conversations
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && 
                    (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && 
                      (request.auth.uid in request.resource.data.participants) &&
                      request.resource.data.participants is list &&
                      (
                        request.resource.data.type == 'private' ||
                        (request.resource.data.type == 'group' && 
                         request.auth.uid in request.resource.data.admins &&
                         request.auth.uid == request.resource.data.createdBy)
                      );
      allow update: if isSignedIn() && 
                      (request.auth.uid in resource.data.participants);
      allow delete: if isConversationAdmin(conversationId);
      
      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);
        allow create: if isSignedIn() && 
                        request.resource.data.senderId == request.auth.uid &&
                        (
                          isConversationParticipant(conversationId) ||
                          !exists(/databases/$(database)/documents/conversations/$(conversationId))
                        );
        allow update: if isSignedIn() && 
                        (resource.data.senderId == request.auth.uid || 
                         isConversationParticipant(conversationId) ||
                         request.resource.data.keys().hasOnly(['status', 'reactions', 'deletedFor', 'isActive', 'closedAt', 'closedBy']));
        allow delete: if resource.data.senderId == request.auth.uid;
      }
    }
    
    // User presence
    match /user_presence/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;
    }
    
    // Message drafts
    match /message_drafts/{userId}/conversations/{conversationId} {
      allow read, write: if request.auth.uid == userId;
    }
    
    // Notification queue
    match /notification_queue/{notificationId} {
      allow read: if request.auth.uid == resource.data.userId;
      allow write: if isSignedIn();
    }
    
    // Top-level messages collection
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.senderId == request.auth.uid;
      // Allow admins to delete messages
      allow delete: if isAdmin();
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }
    
    // Marketplace collection
    match /marketplace/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Screen sharing rooms
    match /screening_rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
      
      match /chat/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }
    
    // Roleplay characters
    match /roleplay_characters/{characterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    match /roleplayCharacters/{characterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Roleplay sessions
    match /roleplay_sessions/{communityId}/sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
      
      match /chat/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }
    
    // Test collection
    match /test/{testId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // User following/followers subcollections
    match /users/{userId}/following/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    match /users/{userId}/followers/{followerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // User notifications subcollection
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
    
    // Reserved usernames collection
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() &&
                     request.auth.uid == request.resource.data.ownerId &&
                     !exists(/databases/$(database)/documents/usernames/$(username));
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
      allow update: if false;
    }

    // Community events
    match /community_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // User events
    match /user_events/{userEventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Friend requests
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && 
                    (resource.data.fromUserId == request.auth.uid || 
                     resource.data.toUserId == request.auth.uid);
      allow create: if isSignedIn() && 
                      request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && 
                      (resource.data.toUserId == request.auth.uid || 
                       resource.data.fromUserId == request.auth.uid);
      allow delete: if isSignedIn() && 
                      (resource.data.fromUserId == request.auth.uid || 
                       resource.data.toUserId == request.auth.uid);
    }
    
    // Friends collection
    match /users/{userId}/friends/{friendId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && 
                     (request.auth.uid == userId || 
                      request.auth.uid == friendId);
    }
    
    // Blocked users collection
    match /users/{userId}/blocked/{blockedUserId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Global Posts collection (Web App: public read)
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                      (request.resource.data.authorId == request.auth.uid || 
                       request.resource.data.userId == request.auth.uid);
      // Allow admins to mark posts as deleted (must come before general update rule)
      allow update: if isAdmin() && 
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['isDeleted', 'deletedAt', 'deletedBy', 'deletionReason']);
      // Allow users to update their own posts
      allow update: if isSignedIn() && 
                      (resource.data.authorId == request.auth.uid || 
                       resource.data.userId == request.auth.uid);
      // Allow admins to delete posts
      allow delete: if isAdmin();
      allow delete: if isSignedIn() && 
                      (resource.data.authorId == request.auth.uid || 
                       resource.data.userId == request.auth.uid);
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        // Allow admins to mark comments as deleted (must come before general update rule)
        allow update: if isAdmin() && 
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['isDeleted', 'deletedAt', 'deletedBy']);
        // Allow users to update their own comments
        allow update: if isSignedIn() && 
                        (resource.data.userId == request.auth.uid || 
                         resource.data.authorId == request.auth.uid);
        // Allow admins to delete comments
        allow delete: if isAdmin();
        allow delete: if isSignedIn() && 
                        (resource.data.userId == request.auth.uid || 
                         resource.data.authorId == request.auth.uid);
      }
    }
    
    // Top-level Comments collection (Web App)
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
      // Allow admins to delete comments
      allow delete: if isAdmin();
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    
    // Stories collection (Web App: public read)
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Allow admins to delete stories
      allow delete: if isAdmin();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // Polls collection (Web App: public read)
    match /polls/{pollId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      match /votes/{voteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }
    
    // Quizzes collection (Web App: public read)
    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      match /attempts/{attemptId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }
    
    // Questions collection (Web App: public read)
    match /questions/{questionId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      match /answers/{answerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }
    
    // ========== ADMIN PANEL COLLECTIONS ==========
    
    // Advertisements collection (Admin Panel)
    match /advertisements/{adId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Blocked Content collection (Admin Panel)
    match /blocked_content/{contentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Join Requests collection (Admin Panel)
    match /join_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Blocked Members collection (Admin Panel)
    match /blocked_members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // Management Records collection (Admin Panel)
    match /management_records/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // ========== REPORTS SYSTEM COLLECTIONS ==========
    
    // Reports collection - User reporting system
    match /reports/{reportId} {
      // Admins can read all reports; users can read their own reports (for duplicate checking);
      // community moderators can read reports scoped to their community.
      allow read: if isAdmin() || 
                    (isSignedIn() && resource.data.reporterId == request.auth.uid) ||
                    (isSignedIn() &&
                      resource.data.communityId != null &&
                      isCommunityModerator(resource.data.communityId));
      
      // Any authenticated user can create a report with validation
      allow create: if isSignedIn() && 
                      request.resource.data.reporterId == request.auth.uid &&
                      request.resource.data.reportedId != request.auth.uid && // Can't report yourself
                      request.resource.data.status == 'pending' && // Must start as pending
                      request.resource.data.isResolved == false && // Must not be pre-resolved
                      request.resource.data.reviewedBy == null && // No pre-assigned reviewer
                      request.resource.data.description.size() <= 500; // Description limit
      
      // Platform admins can update any field.
      // Community moderators can only update community-scoped reports with limited fields.
      allow update: if (isAdmin() && 
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'reviewedBy', 'reviewedAt', 'updatedAt', 
                                    'actionTaken', 'actionDetails', 'adminNotes', 'isResolved', 'priority'])) ||
                       (isSignedIn() &&
                        resource.data.communityId != null &&
                        isCommunityModerator(resource.data.communityId) &&
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['status', 'actionTaken', 'communityReviewedBy',
                                    'communityReviewedAt', 'adminNotes', 'isResolved', 'updatedAt']));
      
      // Only admins can delete reports
      allow delete: if isAdmin();
    }
    
    // Admin Actions Log - tracks all admin moderation actions
    match /admin_actions/{actionId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      // Actions log is immutable - no updates or deletes allowed
      allow update: if false;
      allow delete: if false;
    }
    
  }
}
